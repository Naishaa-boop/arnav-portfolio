<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Arnav</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Syne:wght@300;400;700&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}body{background:#0c0b09;color:#f2ede4;font-family:'Syne',sans-serif;overflow-x:hidden}
#loader{position:fixed;inset:0;z-index:10000;background:#0c0b09;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2rem}#loader.done{opacity:0;visibility:hidden}
.loader-name{font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300;letter-spacing:0.12em;overflow:hidden}
.loader-name span{display:inline-block;transform:translateY(100%);animation:slideUp 1.2s forwards}
.loader-name span:nth-child(1){animation-delay:0.1s}.loader-name span:nth-child(2){animation-delay:0.2s}.loader-name span:nth-child(3){animation-delay:0.3s}.loader-name span:nth-child(4){animation-delay:0.4s}.loader-name span:nth-child(5){animation-delay:0.5s}
@keyframes slideUp{from{transform:translateY(110%)}to{transform:translateY(0)}}
#nav{position:fixed;top:0;left:0;right:0;z-index:500;padding:2rem 3.5rem;display:flex;justify-content:space-between;align-items:center}#nav::before{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(12,11,9,0.8),transparent);backdrop-filter:blur(10px);pointer-events:none}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.4rem;position:relative;z-index:1;color:#f2ede4;text-decoration:none}
.nav-links{display:flex;gap:3rem;list-style:none;position:relative;z-index:1}
.nav-links a{font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(242,237,228,0.55);text-decoration:none}
#hero{position:relative;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden}
.hero-slide{position:absolute;inset:0;background-size:cover;opacity:0;transition:opacity 2.5s}
.hero-slide.active{opacity:1}
.hs1{background:linear-gradient(160deg,#141008 0%,#1c1a0e 30%,#0a1014 70%,#050709 100%)}
.hs2{background:linear-gradient(200deg,#0e1510 0%,#122214 40%,#080d0a 100%)}
.hs3{background:linear-gradient(140deg,#120c07 0%,#1f1208 40%,#0a0806 100%)}
.hero-content{position:relative;z-index:2;text-align:center;max-width:1000px}
.hero-headline{font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300;line-height:1.08;margin-bottom:2rem;opacity:0;animation:fadeIn 1.2s 3s forwards}
.hero-sub{font-size:0.85rem;letter-spacing:0.12em;color:rgba(242,237,228,0.45);max-width:480px;margin:0 auto 3.5rem;opacity:0;animation:fadeIn 1s 3.3s forwards}
.hero-cta{display:inline-block;padding:1rem 2.5rem;border:1px solid rgba(184,151,90,0.4);color:#f2ede4;text-decoration:none;font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;position:relative;overflow:hidden;opacity:0;animation:fadeIn 1s 3.6s forwards;transition:all 0.4s}
.hero-cta::before{content:'';position:absolute;inset:0;background:#b8975a;transform:scaleX(0);transform-origin:left;transition:transform 0.5s}
.hero-cta:hover::before{transform:scaleX(1)}.hero-cta:hover{color:#0c0b09}
.hero-cta span{position:relative;z-index:1}
.slide-indicators{position:absolute;bottom:3rem;left:50%;transform:translateX(-50%);display:flex;gap:0.7rem;z-index:3}
.slide-dot{width:20px;height:1px;background:rgba(242,237,228,0.2);cursor:pointer;transition:all 0.3s}
.slide-dot.active{background:#b8975a;width:40px}
.marquee-wrap{overflow:hidden;padding:4rem 0;border-top:1px solid rgba(242,237,228,0.04);border-bottom:1px solid rgba(242,237,228,0.04)}
.marquee-track{display:flex;white-space:nowrap;animation:marquee 22s linear infinite}
.marquee-item{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;font-style:italic;color:rgba(242,237,228,0.12);padding:0 3rem}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
#about{min-height:100vh;background:#f2ede4;color:#0c0b09;padding:8rem 5rem;display:grid;grid-template-columns:1fr 1fr}
.about-visual{background-image:url('portrait.jpg');background-size:cover;background-position:center}
.about-text{display:flex;flex-direction:column;justify-content:center}
.s-label{font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:#b8975a;margin-bottom:1.5rem}
.about-title{font-family:'Cormorant Garamond',serif;font-size:3.8rem;font-weight:300;margin-bottom:3rem}
.about-body{font-size:0.95rem;line-height:2;max-width:420px}
.about-stat-row{display:flex;gap:3rem;margin-top:4rem;padding-top:3rem;border-top:1px solid rgba(12,11,9,0.1)}
.about-stat .num{font-family:'Cormorant Garamond',serif;font-size:2.8rem;color:#b8975a}
.about-stat .slbl{font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:#7a7060;margin-top:0.4rem}
#portfolio{padding:0;background:#0c0b09}
.gallery-intro{padding:8rem 3.5rem 5rem;display:flex;justify-content:space-between}
.s-title{font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300}
.gallery-cat-title{padding:0 3.5rem 2rem;display:flex;align-items:center;gap:2rem}
.cat-name{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;font-style:italic;color:rgba(242,237,228,0.3)}
.cat-line{flex:1;height:1px;background:rgba(242,237,228,0.06)}
.h-scroll{display:flex;gap:4px;overflow-x:auto;padding:0 3.5rem 4px;scroll-behavior:smooth}
.h-scroll::-webkit-scrollbar{display:none}
.grid-cell{flex:0 0 auto;position:relative;overflow:hidden}
.grid-cell.tall{width:380px;height:520px}.grid-cell.wide{width:600px;height:380px}.grid-cell.sq{width:380px;height:380px}
.cell-media{width:100%;height:100%;background-size:cover;background-position:center;transition:transform 0.8s}
.grid-cell:hover .cell-media{transform:scale(1.1)}
.cell-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,11,9,0.85) 0%,transparent 55%);opacity:0;transition:opacity 0.5s}
.grid-cell:hover .cell-overlay{opacity:1}
.cell-info{position:absolute;bottom:0;left:0;right:0;padding:2rem;transform:translateY(12px);opacity:0;transition:all 0.5s}
.grid-cell:hover .cell-info{transform:translateY(0);opacity:1}
.cell-name{font-family:'Cormorant Garamond',serif;font-size:1.3rem}
#video-section{background:#0c0b09;padding:8rem 0}
.video-inner{max-width:1000px;margin:0 auto;padding:0 3.5rem}
.video-heading{font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300;margin-bottom:4rem;text-align:center}
.video-frame{position:relative;aspect-ratio:16/9;overflow:hidden;background:#050505;border-radius:8px;box-shadow:0 20px 80px rgba(12,11,9,0.8)}
.video-frame video{width:100%;height:100%;object-fit:cover}
.video-placeholder-bg{position:absolute;inset:0;background:linear-gradient(160deg,#0d1520 0%,#08100e 50%,#120d07 100%);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2rem}
.video-placeholder-bg.hidden{opacity:0;pointer-events:none}
.play-btn{width:72px;height:72px;border:1px solid rgba(184,151,90,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(184,151,90,0.08);transition:all 0.4s;cursor:pointer}
.play-btn:hover{background:rgba(184,151,90,0.2);border-color:#b8975a;transform:scale(1.2)}
.play-btn svg{width:22px;height:22px;fill:#b8975a}
#spaces{min-height:100vh;background:#f2ede4;display:flex;overflow:hidden}
.spaces-left{width:42%;padding:8rem 4rem;display:flex;flex-direction:column;justify-content:center}
.spaces-right{flex:1;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:3px}
.spaces-cell{overflow:hidden}.spaces-cell:first-child{grid-row:span 2}
.sc-bg{width:100%;height:100%;background-size:cover;background-position:center;transition:transform 0.8s}.spaces-cell:hover .sc-bg{transform:scale(1.08)}
#services{background:#0c0b09;padding:10rem 3.5rem}
.services-top{display:flex;justify-content:space-between;margin-bottom:6rem}
.service-row{display:flex;padding:3rem 0;border-top:1px solid rgba(242,237,228,0.06);gap:3rem;transition:all 0.3s}
.service-row:hover{padding-left:1rem}
.svc-num{font-family:'Cormorant Garamond',serif;font-size:1.1rem;min-width:50px}
.svc-name{font-family:'Cormorant Garamond',serif;font-size:2.2rem;min-width:320px;transition:all 0.3s}
.service-row:hover .svc-name{color:#b8975a;text-shadow:0 0 20px rgba(184,151,90,0.3)}
.svc-desc{font-size:0.82rem;color:#7a7060;max-width:380px}
#collab{background:#0a0908;padding:8rem 3.5rem;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center}
.collab-tag{font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;border:1px solid rgba(184,151,90,0.3);color:#b8975a;padding:0.4rem 1rem;margin-bottom:2rem}
.collab-title{font-family:'Cormorant Garamond',serif;font-size:3.5rem;margin-bottom:2rem}
.collab-note{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-style:italic;color:rgba(242,237,228,0.6)}
#contact{min-height:100vh;background:#f2ede4;color:#0c0b09;display:flex;align-items:center}
.contact-inner{max-width:900px;margin:0 auto;padding:8rem 3.5rem}
.contact-headline{font-family:'Cormorant Garamond',serif;font-size:7rem;font-weight:300;margin-bottom:4rem}
.contact-links-row{display:flex;gap:4rem;flex-wrap:wrap}
.c-link-label{font-size:0.58rem;letter-spacing:0.35em;text-transform:uppercase;color:#7a7060}
.c-link-val{font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:#0c0b09;text-decoration:none;transition:all 0.3s}
.c-link-val:hover{color:#b8975a;transform:translateX(10px)}
footer{background:#0c0b09;padding:3rem 3.5rem;display:flex;justify-content:space-between;border-top:1px solid rgba(242,237,228,0.05)}
.foot-copy{font-size:0.62rem;color:rgba(242,237,228,0.2)}.foot-brand{font-family:'Cormorant Garamond',serif;color:rgba(242,237,228,0.25)}
.progress-bar{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#b8975a,#d4b07a);z-index:9999;width:0}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@media(max-width:900px){#about{grid-template-columns:1fr}.nav-links{display:none}.grid-cell.tall{width:260px;height:380px}.grid-cell.wide{width:400px;height:260px}footer{flex-direction:column}}
</style>
</head>
<body>
<div id="loader">
  <div class="loader-name"><span>A</span><span>r</span><span>n</span><span>a</span><span>v</span></div>
</div>
<div class="progress-bar" id="progressBar"></div>
<nav id="nav">
  <a href="#hero" class="nav-logo">Arnav</a>
  <ul class="nav-links">
    <li><a href="#portfolio">Work</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Connect</a></li>
  </ul>
</nav>
<section id="hero">
  <div class="hero-slide hs1 active"></div>
  <div class="hero-slide hs2"></div>
  <div class="hero-slide hs3"></div>
  <div class="hero-content">
    <h1 class="hero-headline">I capture what a place <em>feels like.</em></h1>
    <p class="hero-sub">Photography rooted in real moments — across people, nature, and lived experiences.</p>
    <a href="#portfolio" class="hero-cta"><span>View Work</span></a>
  </div>
  <div class="slide-indicators">
    <div class="slide-dot active" onclick="goSlide(0)"></div>
    <div class="slide-dot" onclick="goSlide(1)"></div>
    <div class="slide-dot" onclick="goSlide(2)"></div>
  </div>
</section>
<div class="marquee-wrap">
  <div class="marquee-track">
    <span class="marquee-item">Wildlife</span><span class="marquee-item">—</span>
    <span class="marquee-item">Nature & Landscapes</span><span class="marquee-item">—</span>
    <span class="marquee-item">People & Life</span><span class="marquee-item">—</span>
    <span class="marquee-item">Travel & Spaces</span><span class="marquee-item">—</span>
  </div>
</div>
<section id="about">
  <div class="about-visual"></div>
  <div class="about-text">
    <p class="s-label">The Photographer</p>
    <h2 class="about-title">Presence over perfection.</h2>
    <div class="about-body">
      <p>Arnav is drawn to real, unfiltered moments — the stillness of nature, wildlife, or quiet expressions of people.</p>
      <p>His work captures presence — the kind that makes you feel like you were there.</p>
    </div>
    <div class="about-stat-row">
      <div class="about-stat"><div class="num">7+</div><div class="slbl">Years</div></div>
      <div class="about-stat"><div class="num">3</div><div class="slbl">Disciplines</div></div>
      <div class="about-stat"><div class="num">∞</div><div class="slbl">Moments</div></div>
    </div>
  </div>
</section>
<section id="portfolio">
  <div class="gallery-intro"><h2 class="s-title">The Portfolio</h2></div>
  <div class="gallery-cat-title"><span class="cat-name">Wildlife</span><div class="cat-line"></div></div>
  <div class="h-scroll">
    <div class="grid-cell wide"><div class="cell-media" style="background-image:url('wildlife-1.jpg')"></div><div class="cell-overlay"></div><div class="cell-info"><p class="cell-name">In the stillness</p></div></div>
    <div class="grid-cell tall"><div class="cell-media" style="background-image:url('wildlife-2.jpg')"></div><div class="cell-overlay"></div><div class="cell-info"><p class="cell-name">Unguarded</p></div></div>
    <div class="grid-cell sq"><div class="cell-media" style="background-image:url('wildlife-3.jpg')"></div><div class="cell-overlay"></div><div class="cell-info"><p class="cell-name">The threshold</p></div></div>
  </div>
  <div style="margin-top:4rem">
    <div class="gallery-cat-title"><span class="cat-name">Nature</span><div class="cat-line"></div></div>
    <div class="h-scroll">
      <div class="grid-cell tall"><div class="cell-media" style="background-image:url('nature-1.jpg')"></div><div class="cell-overlay"></div><div class="cell-info"><p class="cell-name">First light</p></div></div>
      <div class="grid-cell wide"><div class="cell-media" style="background-image:url('nature-2.jpg')"></div><div class="cell-overlay"></div><div class="cell-info"><p class="cell-name">Ancient canopy</p></div></div>
      <div class="grid-cell sq"><div class="cell-media" style="background-image:url('nature-3.jpg')"></div><div class="cell-overlay"></div><div class="cell-info"><p class="cell-name">Still water</p></div></div>
    </div>
  </div>
</section>
<section id="video-section">
  <div class="video-inner">
    <h2 class="video-heading">Moving stories.</h2>
    <div class="video-frame" id="videoFrame">
      <video id="mainVideo" style="width:100%;height:100%;object-fit:cover">
        <source src="reel.mp4" type="video/mp4"/>
      </video>
      <div class="video-placeholder-bg" id="videoPlaceholder">
        <div class="play-btn" onclick="handlePlay()"><svg viewBox="0 0 24 24"><path d="M5 3l14 9-14 9V3z" fill="currentColor"/></svg></div>
      </div>
    </div>
  </div>
</section>
<section id="spaces">
  <div class="spaces-left">
    <h2 class="s-title">Beyond Subjects Into Spaces</h2>
    <p>Light, mood, texture, and the way people interact with environments.</p>
  </div>
  <div class="spaces-right">
    <div class="spaces-cell"><div class="sc-bg" style="background-image:url('space-1.jpg')"></div></div>
    <div class="spaces-cell"><div class="sc-bg" style="background-image:url('space-2.jpg')"></div></div>
    <div class="spaces-cell"><div class="sc-bg" style="background-image:url('space-3.jpg')"></div></div>
  </div>
</section>
<section id="services">
  <div class="services-top"><h2 class="s-title">What I offer</h2></div>
  <div class="service-row">
    <span class="svc-num">01</span><h3 class="svc-name">Natural Light</h3>
    <p class="svc-desc">Spaces in their most honest form.</p>
  </div>
  <div class="service-row">
    <span class="svc-num">02</span><h3 class="svc-name">Storytelling Visuals</h3>
    <p class="svc-desc">Imagery that communicates feeling first.</p>
  </div>
</section>
<section id="contact">
  <div class="contact-inner">
    <h2 class="contact-headline">Let's connect.</h2>
    <div class="contact-links-row">
      <div>
        <span class="c-link-label">Email</span>
        <a href="mailto:hello@arnav.photography" class="c-link-val">hello@arnav.photography</a>
      </div>
    </div>
  </div>
</section>
<footer>
  <span class="foot-copy">© 2025 Arnav</span>
  <span class="foot-brand">Visual Storyteller</span>
</footer>
<script>
window.addEventListener('load',()=>{setTimeout(()=>{document.getElementById('loader').classList.add('done')},2400)});
const progressBar = document.getElementById('progressBar');
window.addEventListener('scroll',()=>{const scrollTop = window.scrollY;const docHeight = document.documentElement.scrollHeight - window.innerHeight;progressBar.style.width = (scrollTop / docHeight) * 100 + '%'});
const slides=document.querySelectorAll('.hero-slide'),dots=document.querySelectorAll('.slide-dot');let cur_s=0,timer;
function goSlide(n){slides[cur_s].classList.remove('active');dots[cur_s].classList.remove('active');cur_s=n;slides[cur_s].classList.add('active');dots[cur_s].classList.add('active');clearInterval(timer);timer=setInterval(()=>goSlide((cur_s+1)%slides.length),6000)}
timer=setInterval(()=>goSlide((cur_s+1)%slides.length),6000);
document.querySelectorAll('.h-scroll').forEach(el=>{let down=false,startX,sl;el.addEventListener('mousedown',e=>{down=true;startX=e.pageX;sl=el.scrollLeft});el.addEventListener('mouseleave',()=>down=false);el.addEventListener('mouseup',()=>down=false);el.addEventListener('mousemove',e=>{if(!down)return;el.scrollLeft=sl-(e.pageX-startX)*1.5})});
const vid=document.getElementById('mainVideo'),ph=document.getElementById('videoPlaceholder');
function handlePlay(){if(vid.src){ph.classList.add('hidden');vid.play()}else{alert('Video will load when you upload reel.mp4')}}
window.addEventListener('scroll',()=>{const nav=document.getElementById('nav');if(window.scrollY>80){nav.style.background='rgba(12,11,9,0.96)';nav.style.backdropFilter='blur(20px)'}else{nav.style.background='';nav.style.backdropFilter=''}});
</script>
</body>
</html>
